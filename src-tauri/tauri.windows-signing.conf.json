{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "windows": {
      "signCommand": {
        "cmd": "powershell.exe",
        "args": [
          "-NoLogo",
          "-NoProfile",
          "-NonInteractive",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "..\\scripts\\sign-windows-artifact.ps1",
          "-File",
          "%1"
        ]
      }
    }
  }
}
