{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "windows": {
      "signCommand": {
        "cmd": "powershell.exe",
        "args": [
          "-NoLogo",
          "-NoProfile",
          "-NonInteractive",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "$root = if ($env:GITHUB_WORKSPACE) { $env:GITHUB_WORKSPACE } else { $PWD }; & (Join-Path $root 'scripts\\sign-windows-artifact.ps1') -File '%1'"
        ]
      }
    }
  }
}
