{
  "manifest_version": 3,
  "name": "CivicNews Browser Bridge",
  "version": "1.0.0",
  "description": "Bridges local CivicNews public records queue and OSINT evidence directly into Claude, ChatGPT, and Gemini.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:12053/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.claude.ai/*",
        "*://*.chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
