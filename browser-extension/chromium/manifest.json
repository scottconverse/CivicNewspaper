{
  "manifest_version": 3,
  "name": "Civic Desk Browser Bridge",
  "version": "1.0.0",
  "key": "",
  "description": "Bridges The Civic Desk story queue and source evidence into Claude, ChatGPT, and Gemini after explicit pairing.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:12053/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Civic Desk Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.claude.ai/*",
        "*://*.chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
